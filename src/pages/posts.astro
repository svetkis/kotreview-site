---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Посты — KotReview" description="Заметки про AI Solo Development, LLM под капотом продукта, агентов и инженерную практику.">
  <div class="container">
    <section class="hero">
      <h1>Посты</h1>
      <p>Короткие и не очень заметки про агентов, промпты, код и то, где всё это ломается.</p>
    </section>

    <div class="card-grid">
      {posts.map((post) => (
        <Card
          href={`/posts/${post.id}/`}
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          tags={post.data.tags}
        />
      ))}
    </div>
  </div>
</Layout>
