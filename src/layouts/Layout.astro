---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'KotReview — Svetlana Meleshkina: .NET, AI engineering, agentic development' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="KotReview" />
    <meta property="og:image" content={new URL('/images/share.png', Astro.site).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL('/images/share.png', Astro.site).toString()} />
    <meta name="theme-color" content="#0f0f12" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <header>
      <div class="container">
        <a class="logo" href="/">
          <img class="logo-mascot" src="/stickers/hello.png" alt="" width="32" height="32" />
          Kot<span>Review</span>
        </a>
        <nav>
          <a href="/about">Обо мне</a>
          <a href="/talks">Доклады</a>
          <a href="/projects">Проекты</a>
          <a href="/posts">Посты</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="container">
        <img class="footer-mascot" src="/stickers/hello.png" alt="Котёнок машет лапкой" width="80" height="80" />
        <p>© {new Date().getFullYear()} Svetlana Meleshkina · KotReview</p>
        <p>
          <a href="https://t.me/kot_review" target="_blank" rel="noopener">Telegram</a><span class="sep"> · </span>
          <a href="https://github.com/svetkis" target="_blank" rel="noopener">GitHub</a><span class="sep"> · </span>
          <a href="https://habr.com/ru/users/svetkis/articles/" target="_blank" rel="noopener">Habr</a><span class="sep"> · </span>
          <a href="https://www.linkedin.com/in/svetlana-meleshkina/" target="_blank" rel="noopener">LinkedIn</a><span class="sep"> · </span>
          <a href="https://t.me/addstickers/KotReview" target="_blank" rel="noopener">Стикеры</a>
        </p>
      </div>
    </footer>
  </body>
</html>
