---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import { getCollection } from 'astro:content';

function extractFirstImage(body: string | undefined): string | undefined {
  if (!body) return undefined;
  const match = body.match(/!\[.*?\]\((.*?)\)/);
  return match ? match[1] : undefined;
}

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((post) => ({
    ...post,
    image: post.data.image || extractFirstImage(post.body),
  }));
---

<Layout title="Посты — KotReview" description="Заметки про AI Solo Development, LLM под капотом продукта, агентов и инженерную практику.">
  <div class="container">
    <section class="hero">
      <h1>Посты</h1>
    </section>

    <div class="card-grid">
      {posts.map((post) => (
        <Card
          href={`/posts/${post.id}/`}
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          tags={post.data.tags}
          image={post.image}
        />
      ))}
    </div>
  </div>
</Layout>
