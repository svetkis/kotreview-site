---
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import Card from '../components/Card.astro';
import { getCollection, getEntry } from 'astro:content';

function cardProps(entry: any) {
  const hrefPrefix =
    entry.collection === 'posts' ? '/posts/' :
    entry.collection === 'talks' ? '/talks/' : '/projects/';
  const title =
    entry.collection === 'projects' && entry.id === 'ai-code-review-benchmark'
      ? 'AI Code Review Benchmark'
      : entry.data.title;
  return {
    ...entry,
    hrefPrefix,
    title,
  };
}

const skills = await Promise.all([
  getEntry('posts', '2026-05-07-три-типа-полезных-ai-скиллов'),
  getEntry('posts', '2026-05-13-анатомия-скилла'),
  getEntry('posts', '2026-06-16-как-готовить-ai-скиллы-от-теории-к-практике'),
]).then((entries) => entries.map(cardProps));

const codeReview = await Promise.all([
  getEntry('talks', 'spb-dotnet-ai-code-review-2025'),
  getEntry('projects', 'ai-code-review-benchmark'),
]).then((entries) => entries.map(cardProps));

const llmInProd = await Promise.all([
  getEntry('talks', 'spb-dotnet-llm-under-hood-2026'),
]).then((entries) => entries.map(cardProps));

function extractFirstImage(body?: string): string | undefined {
  if (!body) return undefined;
  const match = body.match(/!\[.*?\]\((.*?)\)/);
  return match ? match[1] : undefined;
}

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5)
  .map((post) => ({
    ...post,
    image: post.data.image || extractFirstImage(post.body),
  }));

const today = new Date();
today.setHours(0, 0, 0, 0);

const isUpcoming = (date: Date) => {
  const d = new Date(date);
  d.setHours(0, 0, 0, 0);
  return d >= today;
};

const talks = (await getCollection('talks'))
  .filter((t) => !t.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const upcomingTalks = talks.filter((t) => isUpcoming(t.data.date));
const latestTalks = talks.filter((t) => !isUpcoming(t.data.date)).slice(0, 3);

const projects = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<Layout title="KotReview — Svetlana Meleshkina" description="Делаю LLM предсказуемой частью продукта и разработки. .NET, AI Solo Development, Agentic Engineering.">
  <div class="container container-wide">
    <section class="hero">
      <div class="hero-grid">
        <div>
          <h1>Светлана Мелешкина</h1>
          <p class="hero-lead">
            Делаю LLM предсказуемой частью продукта и разработки:
            от AI code review до агентов, от .NET до production.
          </p>
          <p>
            Превращаю LLM из непредсказуемой магии в предсказуемый и надёжный компонент —
            который стабильно работает под капотом продукта или в цикле разработки.
          </p>
          <SocialLinks />
        </div>
        <img class="hero-photo" src="/images/author.jpg" alt="Светлана Мелешкина" width="280" height="280" />
      </div>
    </section>

    <section class="proof-section">
      <div class="proof-grid">
        <div class="proof">
          <strong>20+</strong>
          <span>лет в enterprise-разработке</span>
        </div>
        <div class="proof">
          <strong>10+</strong>
          <span>лет в .NET и промышленных системах</span>
        </div>
        <div class="proof">
          <strong>Доклады</strong>
          <span>DotNext, SPbDotNet</span>
        </div>
        <div class="proof">
          <strong>Реальные проекты</strong>
          <span>Telegram-боты, AI code review benchmark, open-source методологии</span>
        </div>
      </div>
    </section>

    <section style="margin-top: 3rem;">
      <h2 class="section-title">С чего начать</h2>

      <h3 class="topic-title">Если вам про AI-скиллы и агентов</h3>
      <div class="card-grid card-grid-2">
        {skills.map((item) => (
          <Card
            href={`${item.hrefPrefix}${item.id}/`}
            title={item.title}
            description={item.data.description}
            date={'date' in item.data ? item.data.date : undefined}
            tags={item.data.tags}
          />
        ))}
      </div>

      <h3 class="topic-title">Если про code review</h3>
      <div class="card-grid card-grid-2">
        {codeReview.map((item) => (
          <Card
            href={`${item.hrefPrefix}${item.id}/`}
            title={item.title}
            description={item.data.description}
            date={'date' in item.data ? item.data.date : undefined}
            tags={item.data.tags}
          />
        ))}
      </div>

      <h3 class="topic-title">Если про LLM в продукте</h3>
      <div class="card-grid card-grid-2">
        {llmInProd.map((item) => (
          <Card
            href={`${item.hrefPrefix}${item.id}/`}
            title={item.title}
            description={item.data.description}
            date={'date' in item.data ? item.data.date : undefined}
            tags={item.data.tags}
          />
        ))}
      </div>
    </section>

    <section style="margin-top: 3rem;">
      <h2 class="section-title">Последние посты</h2>
      <div class="card-grid">
        {posts.map((post) => (
          <Card
            href={`/posts/${post.id}/`}
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            image={post.image}
          />
        ))}
      </div>
      <p style="margin-top: 1rem;"><a href="/posts">Все записи →</a></p>
    </section>

    {upcomingTalks.length > 0 && (
      <section style="margin-top: 3rem;">
        <h2 class="section-title">Предстоящие доклады</h2>
        <div class="card-grid card-grid-2">
          {upcomingTalks.map((talk) => (
            <Card
              href={`/talks/${talk.id}/`}
              title={talk.data.title}
              description={talk.data.description}
              date={talk.data.date}
              tags={talk.data.tags}
              meta="предстоящий"
            />
          ))}
        </div>
      </section>
    )}

    <section style="margin-top: 3rem;">
      <h2 class="section-title">Доклады</h2>
      <div class="card-grid card-grid-2">
        {latestTalks.map((talk) => (
          <Card
            href={`/talks/${talk.id}/`}
            title={talk.data.title}
            description={talk.data.description}
            date={talk.data.date}
            tags={talk.data.tags}
          />
        ))}
      </div>
      <p style="margin-top: 1rem;"><a href="/talks">Все доклады →</a></p>
    </section>

    <section style="margin-top: 3rem;">
      <h2 class="section-title">Проекты</h2>
      <div class="card-grid card-grid-2">
        {projects.map((project) => (
          <Card
            href={`/projects/${project.id}/`}
            title={project.data.title}
            description={project.data.description}
            tags={project.data.tags}
            meta={project.data.status === 'beta' ? 'beta' : project.data.status === 'done' ? 'завершён' : 'активен'}
          />
        ))}
      </div>
      <p style="margin-top: 1rem;"><a href="/projects">Все проекты →</a></p>
    </section>
  </div>
</Layout>
