---
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import Card from '../components/Card.astro';
import { getCollection, getEntry } from 'astro:content';

function extractFirstImage(body?: string): string | undefined {
  if (!body) return undefined;
  const match = body.match(/!\[.*?\]\((.*?)\)/);
  return match ? match[1] : undefined;
}

const featuredEntries = await Promise.all([
  getEntry('posts', '2026-05-07-три-типа-полезных-ai-скиллов'),
  getEntry('posts', '2026-05-13-анатомия-скилла'),
  getEntry('posts', '2026-06-16-как-готовить-ai-скиллы-от-теории-к-практике'),
  getEntry('talks', 'spb-dotnet-llm-under-hood-2026'),
  getEntry('talks', 'spb-dotnet-ai-code-review-2025'),
  getEntry('projects', 'ai-code-review-benchmark'),
]);

const featured = featuredEntries.map((entry) => {
  const hrefPrefix =
    entry.collection === 'posts' ? '/posts/' :
    entry.collection === 'talks' ? '/talks/' : '/projects/';
  const title =
    entry.collection === 'projects'
      ? entry.id === 'ai-code-review-benchmark'
        ? 'AI Code Review Benchmark'
        : entry.data.title
      : entry.data.title;
  return {
    ...entry,
    hrefPrefix,
    title,
    image: entry.collection === 'posts' ? (entry.data.image || extractFirstImage(entry.body)) : undefined,
  };
});

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5)
  .map((post) => ({
    ...post,
    image: post.data.image || extractFirstImage(post.body),
  }));

const talks = (await getCollection('talks'))
  .filter((t) => !t.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const projects = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<Layout title="KotReview — Svetlana Meleshkina" description="Делаю LLM предсказуемой частью продукта и разработки. .NET, AI Solo Development, Agentic Engineering.">
  <div class="container">
    <section class="hero">
      <div class="hero-grid">
        <div>
          <h1>Светлана Мелешкина</h1>
          <p>
            Превращаю LLM из непредсказуемой магии в предсказуемый и надёжный компонент —
            который стабильно работает под капотом продукта или в цикле разработки.
          </p>
          <SocialLinks />
        </div>
        <img class="hero-photo" src="/images/author.jpg" alt="Светлана Мелешкина" width="280" height="280" />
      </div>
    </section>

    <section style="margin-top: 3rem;">
      <h2 class="section-title">С чего начать</h2>
      <div class="card-grid card-grid-2">
        {featured.map((item) => (
          <Card
            href={`${item.hrefPrefix}${item.id}/`}
            title={item.title}
            description={item.data.description}
            date={'date' in item.data ? item.data.date : undefined}
            tags={item.data.tags}
            image={item.image}
          />
        ))}
      </div>
    </section>

    <section style="margin-top: 3rem;">
      <h2 class="section-title">Последние посты</h2>
      <div class="card-grid">
        {posts.map((post) => (
          <Card
            href={`/posts/${post.id}/`}
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            image={post.image}
          />
        ))}
      </div>
      <p style="margin-top: 1rem;"><a href="/posts">Все записи →</a></p>
    </section>

    <section style="margin-top: 3rem;">
      <h2 class="section-title">Доклады</h2>
      <div class="card-grid card-grid-2">
        {talks.map((talk) => (
          <Card
            href={`/talks/${talk.id}/`}
            title={talk.data.title}
            description={talk.data.description}
            date={talk.data.date}
            tags={talk.data.tags}
          />
        ))}
      </div>
      <p style="margin-top: 1rem;"><a href="/talks">Все доклады →</a></p>
    </section>

    <section style="margin-top: 3rem;">
      <h2 class="section-title">Проекты</h2>
      <div class="card-grid card-grid-2">
        {projects.map((project) => (
          <Card
            href={`/projects/${project.id}/`}
            title={project.data.title}
            description={project.data.description}
            tags={project.data.tags}
            meta={project.data.status === 'beta' ? 'beta' : project.data.status === 'done' ? 'завершён' : 'активен'}
          />
        ))}
      </div>
      <p style="margin-top: 1rem;"><a href="/projects">Все проекты →</a></p>
    </section>
  </div>
</Layout>
